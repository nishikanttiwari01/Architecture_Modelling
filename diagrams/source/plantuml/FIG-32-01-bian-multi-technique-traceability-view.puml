@startuml
!include ../../styles/plantuml-theme.puml
title FIG-32-01: Horizon Bank multi-technique relationship view
top to bottom direction
skinparam defaultFontSize 11
skinparam ArrowFontSize 11
skinparam packageTitleFontSize 11
skinparam defaultTextAlignment center
skinparam nodesep 10
skinparam ranksep 18
skinparam packageStyle rectangle

package "BAND 1: BUSINESS AND BIAN" #F7FAFC {
  rectangle "Business need\nImprove outgoing retail payments\nCapability: Payment Initiation" as CAP #EAF2F8
  rectangle "BIAN behaviour\nOutgoing customer payment\nBusiness Scenario" as SCEN #FFF2CC
  rectangle "BIAN responsibility\nCandidate payment-handling\nService Domain responsibility" as SD #FFF2CC
  CAP -right-> SCEN : frames
  SD -left-> SCEN : participates in
}

package "BAND 2: APPLICATION AND EXCHANGE" #F7FAFC {
  rectangle "Horizon application\nPayments Platform" as APP #E2F0D9
  rectangle "Interface / API\nOutgoing Payment API" as API #E2F0D9
  rectangle "Data: Payment Instruction\nEvent: PaymentInstructionAccepted" as EVENT #EDE7F6
  APP -right-> API : supports
  API -right-> EVENT : consumes or produces
}

package "BAND 3: RUNTIME AND QUALIFICATION" #F7FAFC {
  rectangle "Deployment\nPayments runtime" as RUN #DDEBF7
  rectangle "QUALIFIED MAPPING\nOne-to-many, many-to-one or transitional\nA Service Domain is not automatically a capability,\nprocess step, application, microservice, interface,\nevent, data entity or deployment unit." as NOTE #FFFFFF
  RUN -[hidden]right-> NOTE
}

CAP -down-> APP : realises in part
SD -down-> API : exchanges meaning through
SCEN -[hidden]down-> API
SD -[hidden]down-> EVENT
APP -down-> RUN : runs on
RUN -up-> EVENT : consumes or produces
@enduml
