@startuml
!include ../../styles/plantuml-theme.puml
scale 700 width
title FIG-31-01: BIAN reference to implementation choices
top to bottom direction
skinparam defaultTextAlignment center
skinparam nodesep 12
skinparam ranksep 18
skinparam rectangle {
  RoundCorner 10
  MinimumWidth 260
}

rectangle "BIAN LOGICAL REFERENCE\nService Landscape: organises responsibilities\nBusiness Scenario: illustrates collaboration\nService Operation: describes an exchange\nBusiness Object Model: defines shared meaning\nSemantic API and event guidance" as REF #EAF2F8

rectangle "HORIZON BANK ASSESSMENT\nMap capabilities, processes, applications,\ndata, owners, gaps and overlaps\n\nCaution: a Service Domain is not\nautomatically a microservice" as MAP #FFF2CC

rectangle "APP\nApplication and component boundaries" as APP #E2F0D9
rectangle "API\nAPI and event contracts" as API #E2F0D9
rectangle "DATA\nData ownership and physical schemas" as DATA #E2F0D9
rectangle "OPS\nSecurity, deployment and operations" as OPS #E2F0D9
APP -[hidden]down- API
API -[hidden]down- DATA
DATA -[hidden]down- OPS

rectangle "IMPLEMENTATION AND OPERATIONAL EVIDENCE\nQuality attributes, tests, telemetry\nand migration constraints" as EVID #FCE4D6

REF --> MAP : informs assessment
MAP --> APP : choose boundaries
MAP --> API : choose contracts
MAP --> DATA : choose ownership
MAP --> OPS : choose controls and runtime
APP --> EVID : APP evidence
API --> EVID : API evidence
DATA --> EVID : DATA evidence
OPS --> EVID : OPS evidence
EVID ..> MAP : revise mapping when evidence disagrees

legend bottom
  Blue: BIAN reference | Yellow: bank interpretation
  Green: physical choices | Peach: evidence and feedback
endlegend
@enduml
