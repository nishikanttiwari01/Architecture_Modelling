@startuml
!include ../../styles/plantuml-theme.puml
title FIG-31-01: From BIAN reference concepts to implementation choices
top to bottom direction

skinparam defaultTextAlignment center
skinparam rectangle {
  RoundCorner 12
}

package "BIAN logical reference" #EAF2F8 {
  rectangle "Service Landscape\norganises responsibilities" as SL
  rectangle "Business Scenario\nillustrates collaboration" as BS
  rectangle "Service Operation\ndescribes an exchange" as SO
  rectangle "Business Object Model\ndefines shared meaning" as BOM
  rectangle "Semantic API and event guidance" as SEM
  SL -[hidden]down- BS
  BS -[hidden]down- SO
  SO -[hidden]down- BOM
  BOM -[hidden]down- SEM
}

rectangle "Horizon Bank assessment\nMap capabilities, processes, applications,\ndata, owners, gaps and overlaps" as MAP #FFF2CC

package "Bank-specific implementation choices" #E2F0D9 {
  rectangle "Application and\ncomponent boundaries" as APP
  rectangle "API and event\ncontracts" as API
  rectangle "Data ownership\nand physical schemas" as DATA
  rectangle "Security, deployment\nand operations" as OPS
  APP -[hidden]down- API
  API -[hidden]down- DATA
  DATA -[hidden]down- OPS
}

rectangle "Implementation and operational evidence\nquality attributes, tests, telemetry and migration constraints" as EVID #FCE4D6
note right of MAP
  Caution
  A Service Domain is not
  automatically a microservice.
end note

SL --> MAP : informs
BS --> MAP : tests collaboration
SO --> MAP : clarifies exchanges
BOM --> MAP : aligns meaning
SEM --> MAP : guides contracts
MAP --> APP : design decisions
MAP --> API : design decisions
MAP --> DATA : design decisions
MAP --> OPS : design decisions
APP --> EVID : produces evidence
API --> EVID
DATA --> EVID
OPS --> EVID
EVID ..> MAP : revise mapping when evidence disagrees

legend bottom
  Blue = BIAN reference | Yellow = bank interpretation
  Green = physical choices | Peach = evidence and feedback
endlegend
@enduml
