@startuml
!include ../../styles/plantuml-theme.puml
title Online Store solution design thread
top to bottom direction
skinparam nodesep 22
skinparam ranksep 30
skinparam defaultFontSize 13

rectangle "Design drivers\nFR-25-01, QA-25-01\nduplicate prevention\nprovider constraint" as D #FFF2CC
rectangle "Options\n1 Synchronous\n2 Asynchronous\n3 Hybrid" as O #DDEBF7
rectangle "ADR-26-01\nSelect hybrid response\nRecord consequences" as A #E4DFEC

package "Coherent design views" #E2F0D9 {
 rectangle "Structure\nResponsibilities and\nboundaries" as S
 rectangle "Interaction\nSuccess, timeout,\nretry and recovery" as I
 rectangle "Information\nOrder and payment\nownership" as N
 rectangle "Security\nTrust boundaries\nand controls" as C
 rectangle "Deployment\nFailure domains and\noperational intent" as P
}

rectangle "Planned evidence\nperformance and retry tests\nfault experiment\nusability validation" as E #FCE4D6

D --> O : shapes comparison
O --> A : decision recorded by
A --> S : realised by
A --> I : realised by
A --> N : realised by
A --> C : realised by
A --> P : realised by
S --> E : assessed through
I --> E : assessed through
N --> E : assessed through
C --> E : assessed through
P --> E : assessed through
E ..> D : feedback refines

legend bottom
Solid arrows show forward trace links.
Dotted arrow shows iterative learning.
endlegend
@enduml
