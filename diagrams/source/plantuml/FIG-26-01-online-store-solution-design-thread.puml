@startuml
!include ../../styles/plantuml-theme.puml
title Online Store solution design thread
top to bottom direction
scale 730 width
skinparam nodesep 18
skinparam ranksep 42
skinparam defaultFontSize 14

rectangle "Design drivers\nFR-25-01 and QA-25-01\nDuplicate prevention\nProvider constraint" as D #FFF2CC
rectangle "Options\n1  Synchronous\n2  Asynchronous\n3  Hybrid" as O #DDEBF7
rectangle "ADR-26-01\nSelect hybrid response\nRecord consequences" as A #E4DFEC

rectangle "Structure view\nResponsibilities\nand boundaries" as S #E2F0D9
rectangle "Interaction view\nSuccess, timeout,\nretry and recovery" as I #E2F0D9
rectangle "Information view\nOrder and payment\nownership" as N #E2F0D9

rectangle "Security view\nTrust boundaries\nand controls" as C #E2F0D9
rectangle "Deployment view\nFailure domains and\noperational intent" as P #E2F0D9

rectangle "Planned evidence\nPerformance and retry tests\nFault experiment\nUsability validation" as E #FCE4D6

D -down-> O : shapes comparison
O -down-> A : decision recorded by

A --> S : realises
A --> I : realises
A --> N : realises
S -[hidden]right-> I
I -[hidden]right-> N

S -[hidden]down-> C
N -[hidden]down-> P
C -[hidden]right-> P
A --> C : realises
A --> P : realises

S --> E : assessed through
I --> E : assessed through
N --> E : assessed through
C --> E : assessed through
P --> E : assessed through

E .up.> D : feedback refines

legend bottom
Solid arrows show forward trace links.
Dotted arrow shows iterative learning.
endlegend
@enduml
