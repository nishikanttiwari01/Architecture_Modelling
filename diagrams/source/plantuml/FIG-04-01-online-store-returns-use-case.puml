@startuml
!include ../../styles/plantuml-theme.puml

left to right direction
title FIG-04-01. Online Store Returns Use Case Diagram

actor Customer
actor "Customer Support Agent" as Support

rectangle "Online Store" as OnlineStore {
  usecase "Request return" as RequestReturn
  usecase "Check return\neligibility" as CheckEligibility
  usecase "Review return\nexception" as ReviewException
  usecase "Request refund" as RequestRefund
  usecase "Request collection" as RequestCollection
}

actor "Payment Provider System" as PaymentProvider
actor "Delivery Partner System" as DeliveryPartner

Customer -- RequestReturn
Support -- ReviewException
RequestRefund -- PaymentProvider
RequestCollection -- DeliveryPartner

RequestReturn ..> CheckEligibility : <<include>>
ReviewException ..> RequestReturn : <<extend>>\n[policy exception]
RequestRefund ..> RequestReturn : <<extend>>\n[approved and refundable]
RequestCollection ..> RequestReturn : <<extend>>\n[collection required]

legend right
  Solid line = actor association
  <<include>> = required behaviour
  <<extend>> = conditional behaviour
endlegend
@enduml
