@startuml
!include ../../styles/plantuml-theme.puml

title FIG-07-06. Horizon Bank implementation and migration view

skinparam linetype ortho
skinparam nodesep 55
skinparam ranksep 65
skinparam rectangle {
  RoundCorner 8
}

left to right direction

rectangle "Current State\n<<Plateau>>\n\nProduct-specific onboarding\nDuplicate customer stores\nCore Deposit System" as current #F7F9FB
rectangle "Transition release\ncompleted\n<<Event>>" as event_transition #FFF4D6
rectangle "Transition State\n<<Plateau>>\n\nCustomer Onboarding Platform\nParty and Customer Platform\nCore Deposit System retained" as transition #F7F9FB
rectangle "Target State\n<<Plateau>>\n\nReusable onboarding service\nCustomer profile service\nReduced duplicate customer capture" as target #F7F9FB

rectangle "Introduce Customer\nOnboarding Platform\n<<Work Package>>" as wp_onboarding #F7E8D0
rectangle "Reusable onboarding\nservice\n<<Deliverable>>" as deliver_onboarding #E8F1FA
rectangle "Introduce Party and\nCustomer Platform\n<<Work Package>>" as wp_party #F7E8D0
rectangle "Customer profile\nservice\n<<Deliverable>>" as deliver_profile #E8F1FA
rectangle "Integrate retained\nCore Deposit System\n<<Work Package>>" as wp_core #F7E8D0
rectangle "Retained core\nintegration\n<<Deliverable>>" as deliver_core #E8F1FA
rectangle "Reduced duplicate\ncustomer capture\n<<Outcome>>" as outcome #EAF6E8

current -right-> event_transition : planned transition
event_transition -right-> transition : release event
transition -right-> target : target adoption

wp_onboarding -right-> deliver_onboarding : realisation
wp_party -right-> deliver_profile : realisation
wp_core -right-> deliver_core : realisation

deliver_onboarding -right-> outcome : influence
deliver_profile -right-> outcome : influence
deliver_core -right-> transition : retained integration

current -[hidden]down-> wp_onboarding
transition -[hidden]down-> wp_party
target -[hidden]down-> outcome

legend bottom
  Plateaus are ordered by layout, not Triggering.
  Events and labelled associations explain movement between states.
  Work Packages realise Deliverables.
  Deliverables influence the Outcome or explain retained integration.
  The removed Gap element is not used.
endlegend
@enduml
