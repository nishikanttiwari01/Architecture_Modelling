<mxCell id="c34" value="progresses to" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;fontSize=10;fontColor=#1D2939;strokeColor=#475467;strokeWidth=1.2;" edge="1" parent="1" source="c18" target="c25"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
<mxCell id="c35" value="Note: This roadmap shows architecture configurations and their dependencies, risks, assumptions, decision points and exit evidence. It deliberately shows no delivery dates, budgets, programme commitments, staffing or vendor decisions. Deliberate legacy coexistence is explicit. The target is a direction under the stated assumptions, not a guaranteed final implementation." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#8A6D3B;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="660" width="1120" height="60" as="geometry"/></mxCell>
