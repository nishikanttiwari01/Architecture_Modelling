        <mxCell id="c2" value="FIG-13-04. Horizon Bank Platform Evolution Roadmap" style="text;html=1;figtitle=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="20" y="10" width="1120" height="34" as="geometry"/></mxCell>
<mxCell id="c3" value="Architecture states, not a project-task list. The target is a direction under stated assumptions." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="20" y="44" width="1120" height="20" as="geometry"/></mxCell>
<mxCell id="c4" value="Current" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D2939;fontColor=#FFFFFF;strokeColor=#1D2939;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="20" y="90" width="270" height="40" as="geometry"/></mxCell>
<mxCell id="c5" value="Core Deposit System (Legacy retained initially) and point-to-point integration remain dominant." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FB;strokeColor=#175CD3;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="140" width="270" height="96" as="geometry"/></mxCell>
<mxCell id="c6" value="Dependency: Core Deposit System availability and direct interfaces." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#475467;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="244" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c7" value="Risk: high reconciliation effort and fragile point-to-point links." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3F2;strokeColor=#B42318;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="310" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c8" value="Assumption: Core Deposit System remains operationally critical." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#475467;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="376" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c9" value="Decision point: agree modernisation approach before adding new direct links." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#8A6D3B;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="442" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c10" value="Exit evidence: current interfaces and reconciliation effort documented." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF3;strokeColor=#027A48;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="508" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c11" value="Near-term transition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D2939;fontColor=#FFFFFF;strokeColor=#1D2939;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="300" y="90" width="270" height="40" as="geometry"/></mxCell>
<mxCell id="c12" value="Payments Platform uses Enterprise Integration Platform (Transitional) adapters instead of new direct core links." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FB;strokeColor=#175CD3;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="300" y="140" width="270" height="96" as="geometry"/></mxCell>
<mxCell id="c13" value="Dependency: Enterprise Integration Platform adapter capability and adapter ownership." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#475467;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="300" y="244" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c14" value="Risk: unclear adapter ownership and insufficient service-level monitoring." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3F2;strokeColor=#B42318;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="300" y="310" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c15" value="Assumption: adapters mediate posting and account-access requests reliably." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#475467;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="300" y="376" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c16" value="Decision point: confirm adapter ownership and operating model." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#8A6D3B;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="300" y="442" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c17" value="Exit evidence: adapters in use with agreed service-level monitoring and assigned ownership." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF3;strokeColor=#027A48;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="300" y="508" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c18" value="Later transition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D2939;fontColor=#FFFFFF;strokeColor=#1D2939;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="580" y="90" width="270" height="40" as="geometry"/></mxCell>
<mxCell id="c19" value="Event Platform (Target) publishes governed payment-status events for approved consumers." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FB;strokeColor=#175CD3;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="580" y="140" width="270" height="96" as="geometry"/></mxCell>
<mxCell id="c20" value="Dependency: Event Platform and Event Governance capability." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#475467;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="580" y="244" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c21" value="Risk: weak event-schema governance, uncontrolled consumer access, missing replay policy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3F2;strokeColor=#B42318;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="580" y="310" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c22" value="Assumption: governed events can replace some point-to-point status queries." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#475467;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="580" y="376" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c23" value="Decision point: approve event-schema governance, consumer access control and replay policy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#8A6D3B;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="580" y="442" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c24" value="Exit evidence: governed events consumed under access control with a defined replay policy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF3;strokeColor=#027A48;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="580" y="508" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c25" value="Target direction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D2939;fontColor=#FFFFFF;strokeColor=#1D2939;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="860" y="90" width="270" height="40" as="geometry"/></mxCell>
<mxCell id="c26" value="Modular payments, customer and data platforms support governed reuse; Core Deposit System retained until exit evidence is accepted." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FB;strokeColor=#175CD3;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="860" y="140" width="270" height="96" as="geometry"/></mxCell>
<mxCell id="c27" value="Dependency: sustained platform investment and retained-core coexistence." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#475467;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="860" y="244" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c28" value="Risk: assuming legacy retires before exit evidence is accepted." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3F2;strokeColor=#B42318;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="860" y="310" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c29" value="Assumption: direction holds under current strategy; not a guaranteed final implementation." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#475467;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="860" y="376" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c30" value="Decision point: review direction if funding, regulation, vendor or risk assumptions change." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#8A6D3B;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="860" y="442" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c31" value="Exit evidence: legacy coexistence removed only when documented exit conditions are met." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF3;strokeColor=#027A48;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="860" y="508" width="270" height="58" as="geometry"/></mxCell>
<mxCell id="c32" value="progresses to" style="edgeStyle=none;rounded=0;html=1;endArrow=classic;fontSize=10;fontColor=#1D2939;strokeColor=#475467;strokeWidth=1.2;" edge="1" parent="1" source="c4" target="c11"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell>
