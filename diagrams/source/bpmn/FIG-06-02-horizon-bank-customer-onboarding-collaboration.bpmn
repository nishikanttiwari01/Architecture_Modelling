      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ValidateApplication" bpmnElement="Task_ValidateApplication">
        <dc:Bounds x="540" y="250" width="120" height="44" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RequestScreening" bpmnElement="Task_RequestScreening">
        <dc:Bounds x="705" y="250" width="120" height="44" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_ReceiveScreeningResult" bpmnElement="Event_ReceiveScreeningResult">
        <dc:Bounds x="882" y="254" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="847" y="295" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ScreeningClear" bpmnElement="Gateway_ScreeningClear" isMarkerVisible="true">
        <dc:Bounds x="990" y="237" width="70" height="70" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="984" y="310" width="83" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_OpenCustomerProfile" bpmnElement="Task_OpenCustomerProfile">
        <dc:Bounds x="1120" y="250" width="125" height="44" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_SendOutcome" bpmnElement="Task_SendOutcome">
        <dc:Bounds x="1290" y="250" width="120" height="44" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_ProfileOpened" bpmnElement="End_ProfileOpened">
        <dc:Bounds x="1462" y="254" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1445" y="295" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ReviewScreeningException" bpmnElement="Task_ReviewScreeningException">
        <dc:Bounds x="1110" y="346" width="150" height="44" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ExceptionDecision" bpmnElement="Gateway_ExceptionDecision" isMarkerVisible="true">
        <dc:Bounds x="1310" y="333" width="70" height="70" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1304" y="405" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_ApplicationRejected" bpmnElement="End_ApplicationRejected">
        <dc:Bounds x="1462" y="350" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1453" y="392" width="54" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_OB_01" bpmnElement="Flow_OB_01">
        <di:waypoint x="323" y="190" />
        <di:waypoint x="365" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OB_02" bpmnElement="Flow_OB_02">
        <di:waypoint x="485" y="190" />
        <di:waypoint x="510" y="190" />
        <di:waypoint x="510" y="272" />
        <di:waypoint x="540" y="272" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OB_03" bpmnElement="Flow_OB_03">
        <di:waypoint x="660" y="272" />
        <di:waypoint x="705" y="272" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OB_04" bpmnElement="Flow_OB_04">
