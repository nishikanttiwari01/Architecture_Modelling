          <dc:Bounds x="1418" y="344" width="27" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Participant_FinancialCrime" bpmnElement="Participant_FinancialCrime" isHorizontal="true">
        <dc:Bounds x="160" y="440" width="1380" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_MessageFlow_Outcome" bpmnElement="MessageFlow_Outcome">
