        <di:waypoint x="1110" y="368" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1048" y="332" width="74" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OB_ClearAfterReview" bpmnElement="Flow_OB_ClearAfterReview">
        <di:waypoint x="1345" y="333" />
