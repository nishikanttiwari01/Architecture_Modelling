        <di:waypoint x="1182" y="313" />
        <di:waypoint x="1182" y="294" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1255" y="294" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OB_06" bpmnElement="Flow_OB_06">
        <di:waypoint x="1245" y="272" />
        <di:waypoint x="1290" y="272" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OB_07" bpmnElement="Flow_OB_07">
        <di:waypoint x="1410" y="272" />
        <di:waypoint x="1462" y="272" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_OB_08" bpmnElement="Flow_OB_08">
