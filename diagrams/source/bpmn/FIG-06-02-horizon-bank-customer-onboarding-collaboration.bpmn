        <bpmndi:BPMNLabel>
          <dc:Bounds x="278" y="212" width="54" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CaptureApplication" bpmnElement="Task_CaptureApplication">
